using System.Collections;
using System.Collections.Generic;
using UnityEngine;
using UnityEngine.SceneManagement;

public class PlayerController : MonoBehaviour
{
    public float movSpeed;
    public int near;
    public int stage2;
    public LayerMask solidObjectsLayer;
    public LayerMask grassLayer;
    public LayerMask Walls;
    public LayerMask DoorsLayer;
    public GameObject Doors1;
    public LayerMask sulfurLayer;
    public GameObject sulfur;
    public GameObject NaCl;
    public GameObject touch;
    public GameObject blank;
    public GameObject water;
    public GameObject water2;
    public GameObject saltwater;
    public GameObject elec;
    public GameObject H2;
    public GameObject He;
    public GameObject HCl;
    public GameObject Door;
    public GameObject Door2;
    public GameObject Benyzl;
    public GameObject tears;
    public GameObject h2so4;
    public GameObject fire;
    public GameObject policeman;
    public GameObject policewoman;

    public string collide;
    public bool change = false;
    private bool isMoving;
    private Vector2 input;
    private Animator animator;
    public TMPController tmpgo;
    private void Awake()
    {
        animator = GetComponent<Animator>();
    }
    void Start(){
        saltwater.SetActive(false);
        HCl.SetActive(false);
        tears.SetActive(false);
        stage2 = 0;
   }

    private void Update(){
        
        if(!isMoving){
            input.x = Input.GetAxisRaw("Horizontal");
            input.y = Input.GetAxisRaw("Vertical");
            if(input.x != 0) input.y = 0;
            if(input != Vector2.zero){
                animator.SetFloat("moveX", input.x);
                animator.SetFloat("moveY", input.y);
                var targetPos = transform.position;
                targetPos.x += input.x;
                targetPos.y += input.y; 
            if(IsWalkable(targetPos))
                StartCoroutine(Move(targetPos));
        }
        }
        animator.SetBool("isMoving", isMoving);
        if(near == 1){
            Debug.Log("Encountered a wild Pokemon");
                if(Input.GetMouseButtonDown(0)){
                    Doors1.SetActive(false);
                }
        }
        if(collide == "blank2" && touch == h2so4){
                Door.SetActive(false);
                tmpgo.tipgo(13,"h2o4");
            }

        
        if(Input.GetMouseButtonDown(0)){
            if(collide =="water_2" && touch == NaCl){
            tmpgo.tipgo(4,"water_2");
            water2.SetActive(false);
            NaCl.SetActive(false);
            saltwater.SetActive(true);
            touch = saltwater;
            stage2+=1;

    
            }
            if(collide == "elec"&&touch == saltwater){
                saltwater.SetActive(false);
                touch = blank;
                tmpgo.tipgo(5,"elec");
                stage2+=1;
            }
            if(collide == "negative"&&touch == H2&&stage2>1 && He.activeSelf){
                H2.SetActive(false);
                touch = blank;
                tmpgo.tipgo(8,"blank");
                stage2+=1;
            }
            if(collide == "negative"&&touch == H2&&stage2>1 && !He.activeSelf){
                H2.SetActive(false);
                touch = blank;
                tmpgo.tipgo(10,"blank");
                stage2+=1;
            }
            if(collide == "positive"&&touch == He&&stage2>1&&H2.activeSelf){
                He.SetActive(false);
                tmpgo.tipgo(5,"blank");
                touch = blank;
                stage2+=1;
            }
            if(collide == "positive"&&touch == He&&stage2>1&&!H2.activeSelf){
                He.SetActive(false);
                tmpgo.tipgo(10,"blank");
                touch = blank;
                stage2+=1;
            }
            if(!He.activeSelf&&!H2.activeSelf&&touch == blank){
                HCl.SetActive(true);
            }
            if(collide == "HCl" && touch == Benyzl&&stage2>3){
                tears.SetActive(true);
                tmpgo.tipgo(12,"blank");
                HCl.SetActive(false);
                Benyzl.SetActive(false);
            }
            else{
            touch = blank;
            }

        }else{
        touch.transform.position = new Vector2 (gameObject.transform.position.x+1,gameObject.transform.position.y);
        }
    
    }

    IEnumerator Move(Vector3 targetPos)
    {
        isMoving = true;

        while((targetPos - transform.position).sqrMagnitude > Mathf.Epsilon)
        {
            transform.position = Vector3.MoveTowards(transform.position, targetPos, movSpeed*Time.deltaTime);
            yield return null;
        }
        transform.position = targetPos;
        isMoving = false;

        CheckForEncounters();
    }
    private bool IsWalkable(Vector3 targetPos)
    {
        if(Physics2D.OverlapCircle(targetPos, 0.2f, solidObjectsLayer) != null)
        {
            return false;
        }
        if(Physics2D.OverlapCircle(targetPos, 0.2f, Walls) != null)
        {
            return false;
        }
        if(Physics2D.OverlapCircle(targetPos, 0.2f, DoorsLayer) != null)
        {
            return false;
        }
        return true;
    }
    private void CheckForEncounters()
    {
        if(Physics2D.OverlapCircle(transform.position, 0.2f, grassLayer) != null)
        {
            if(Random.Range(1, 101)<10)
            {
                Debug.Log("Encountered a wild Pokemon");
            }
        }
        if(Physics2D.OverlapCircle(transform.position, 0.5f, DoorsLayer) != null)
        {
            near = 1;
        }
        else{
            near = 0;
        }

        /*if(Physics2D.OverlapCircle(transform.position, 0.5f, sulfurLayer) != null)
        {
            sulfur.transform.position = new Vector2 (transform.position.x,transform.position.y);
            Debug.Log("hello");
        }*/
        
    }

    void OnCollisionEnter2D(Collision2D collision) 
    {
        
        if(collision.gameObject.name == "sulfur"){
            tmpgo.tipgo(0,"sulfur");
            collision.gameObject.GetComponent<Sulfur>().touch = 1;
            talkall.talkgo();
        }
        if(collision.gameObject.name == "so2"){
            tmpgo.tipgo(1,"so2");
            collision.gameObject.GetComponent<so2>().touch = 1;
        }
        if(collision.gameObject.name == "h2so4"){
            touch = h2so4;
            tmpgo.tipgo(2,"h2so4");
            collision.gameObject.GetComponent<h2so4>().touch = 1;
        }
        if(collision.gameObject.name == "NaCl" && touch == blank){
            tmpgo.tipgo(3,"NaCl");
            touch = NaCl;
        }
        if(collision.gameObject.name == "water_2"){
            collide = "water_2";
        }
        if(collision.gameObject.name == "saltwater" && touch == blank){
            touch = saltwater;
        }
        if(collision.gameObject.name == "elec"){
            collide = "elec";
        }
        if(collision.gameObject.name == "H2" && touch == blank&&stage2>1){
            touch = H2;
            if(saltwater.activeSelf){
                tmpgo.tipgo(6,"H2");
            }else{
                tmpgo.tipgo(7,"H2");
            }
        }
        if(collision.gameObject.name == "He" && touch == blank&&stage2>1){
            touch = He;
            if(saltwater.activeSelf){
                tmpgo.tipgo(6,"H2");
            }else{
                tmpgo.tipgo(9,"He");
            }
        }
        if(collision.gameObject.name == "negative"){
            collide = "negative";
        }
        if(collision.gameObject.name == "positive"){
            collide = "positive";
        }
        if(collision.gameObject.name == "HCl"){
            collide = "HCl";
        }
        if(collision.gameObject.name == "blank2"){
            collide = "blank2";
        }
        if(collision.gameObject.name == "Benyzl"&&stage2>3){
            touch = Benyzl;
            tmpgo.tipgo(11,"Benyzl");
        }
        if(collision.gameObject.name == "Tears"){
            touch = tears;
        }
        if(collision.gameObject.name == "fire"){
            collide = "fire";
            tears.SetActive(false);
            policeman.SetActive(false);
            policewoman.SetActive(false);
            StartCoroutine(DelayAndLoadScene());
                    }
        Debug.Log(collision.gameObject.name);
    }
    private IEnumerator DelayAndLoadScene()
    {
        yield return new WaitForSeconds(1f);
        SceneManager.LoadSceneAsync("Continue");
    }
}

